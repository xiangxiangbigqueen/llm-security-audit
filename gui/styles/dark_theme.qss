/* CodeSentinel Dark Theme */
QMainWindow {
    background-color: #1a1a2e;
}

QWidget {
    background-color: #16213e;
    color: #eaeaea;
    font-family: "SF Pro Display", "Helvetica Neue", sans-serif;
    font-size: 13px;
}

QLabel {
    color: #eaeaea;
}

QPushButton {
    background-color: #e94560;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #ff6b6b;
}

QPushButton:pressed {
    background-color: #c23152;
}

QPushButton:disabled {
    background-color: #4a4a6a;
    color: #888;
}

QPushButton#stopButton {
    background-color: #6c757d;
}

QLineEdit {
    background-color: #0f3460;
    border: 1px solid #3a3a5c;
    border-radius: 4px;
    padding: 8px;
    color: #eaeaea;
}

QLineEdit:focus {
    border-color: #e94560;
}

QTextEdit, QPlainTextEdit {
    background-color: #0f3460;
    border: 1px solid #3a3a5c;
    border-radius: 4px;
    color: #eaeaea;
    font-family: "JetBrains Mono", "Fira Code", monospace;
    font-size: 12px;
}

QTableWidget {
    background-color: #0f3460;
    border: 1px solid #3a3a5c;
    gridline-color: #3a3a5c;
}

QTableWidget::item {
    padding: 5px;
}

QTableWidget::item:selected {
    background-color: #e94560;
}

QHeaderView::section {
    background-color: #1a1a2e;
    color: #eaeaea;
    padding: 8px;
    border: 1px solid #3a3a5c;
    font-weight: bold;
}

QTabWidget::pane {
    border: 1px solid #3a3a5c;
    background-color: #16213e;
}

QTabBar::tab {
    background-color: #0f3460;
    color: #aaa;
    padding: 8px 16px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

QTabBar::tab:selected {
    background-color: #16213e;
    color: #e94560;
    font-weight: bold;
}

QProgressBar {
    border: 1px solid #3a3a5c;
    border-radius: 4px;
    text-align: center;
    background-color: #0f3460;
}

QProgressBar::chunk {
    background-color: #e94560;
    border-radius: 3px;
}

QTreeWidget {
    background-color: #0f3460;
    border: 1px solid #3a3a5c;
}

QTreeWidget::item:selected {
    background-color: #e94560;
}

QSplitter::handle {
    background-color: #3a3a5c;
}